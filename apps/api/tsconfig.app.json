{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "rootDir": "../..",
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2021",
    "paths": {
      "@core": ["../../libs/core/src/index.ts"],
      "@web-shared": ["../../libs/web-shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../../libs/core/src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "../../libs/core/src/**/*.spec.ts"
  ]
}
